# circuit-node-client environment variables
# Copy to .env and fill in values. All are optional — see notes below.

# ── Chat / LLM ────────────────────────────────────────────────────────────────
# OpenRouter API key for the chat interface.
# Only needed if you're not pairing a circuit-agent (the agent's own key is used
# automatically when agentDataPath is set in config/client.json).
# Get a key at: https://openrouter.ai
OPENROUTER_API_KEY=

# ── Operator use only ─────────────────────────────────────────────────────────
# These are only needed when running deploy/publish-update.js to push a new
# version to the network. Do not set these on user nodes.

# URL of the canonical circuit-node registry (defaults to https://node.circuitllm.xyz)
# REGISTRY_URL=https://node.circuitllm.xyz

# Internal authentication key for the canonical node (operator only)
# INTERNAL_KEY=
